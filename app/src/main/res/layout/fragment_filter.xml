<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/filter_settings"
        app:titleTextAppearance="@style/TopBarTitleStyleFilter" />

    <!-- Место работы -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutWorkLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ivWorkLocationIcon">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/work_location"
                android:textColor="@color/text_hint"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular"/>

            <TextView
                android:id="@+id/tvWorkLocationValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/not_selected"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:fontFamily="@font/ys_display_regular"
                android:visibility="gone"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivWorkLocationIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_forward_go"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/filter_icon" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Отрасль -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutIndustry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutWorkLocation">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ivIndustryIcon">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/industry"
                android:textColor="@color/text_hint"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular"/>

            <TextView
                android:id="@+id/tvIndustryValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/not_selected"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:fontFamily="@font/ys_display_regular"
                android:visibility="gone"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivIndustryIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_forward_go"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/filter_icon" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Ожидаемая зарплата -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSalary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_input_salary"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutIndustry">

        <TextView
            android:id="@+id/tvSalaryHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ожидаемая зарплата"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:fontFamily="@font/ys_display_regular"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/etSalary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@null"
            android:hint="Введите сумму"
            android:inputType="number"
            android:textColor="@color/black"
            android:textColorHint="@color/text_hint"
            android:textSize="16sp"
            android:fontFamily="@font/ys_display_regular"
            app:layout_constraintEnd_toStartOf="@+id/ivSalaryClear"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSalaryHeader" />

        <ImageView
            android:id="@+id/ivSalaryClear"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/close_24px_for_edit_text"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/layoutSalary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/layoutSalary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Не показывать без зарплаты -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHideWithoutSalary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutSalary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/hide_without_salary"
            android:textColor="@color/text_vacancy_detail"
            android:textSize="16sp"
            android:fontFamily="@font/ys_display_regular"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cbHideWithoutSalary" />

        <CheckBox
            android:id="@+id/cbHideWithoutSalary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@drawable/checkbox_blue"
            app:buttonTint="@null"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Отступ для кнопок (занимает все свободное место) -->
    <View
        android:id="@+id/spacer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutHideWithoutSalary" />

    <!-- Контейнер для кнопок -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/ys_display_medium"
            android:text="@string/apply"
            android:textColor="@color/white"
            app:backgroundTint="@color/blue"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:fontFamily="@font/ys_display_medium"
            android:text="@string/reset"
            android:textColor="@color/red" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
