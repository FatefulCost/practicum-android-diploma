<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        android:paddingStart="4dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorOnSurface"
        app:title="@string/select_work_location"
        app:titleTextAppearance="@style/TopBarTitleStyle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <!-- Строка выбора страны -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/layoutCountry"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvCountryLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/country"
                android:textColor="@color/gray"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular" />

            <TextView
                android:id="@+id/tvCountryValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text=""
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivCountryArrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/gray" />

            <ImageView
                android:id="@+id/ivCountryClear"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/close_24px"
                android:tint="@color/gray"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- Строка выбора региона -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/layoutRegion"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvRegionLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/region"
                android:textColor="@color/gray"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular" />

            <TextView
                android:id="@+id/tvRegionValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text=""
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:fontFamily="@font/ys_display_regular"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivRegionArrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/gray" />

            <ImageView
                android:id="@+id/ivRegionClear"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/close_24px"
                android:tint="@color/gray"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </LinearLayout>

    <!-- Кнопка Выбрать (изначально скрыта) -->
    <Button
        android:id="@+id/btnSelect"
        android:layout_width="match_parent"
        android:layout_height="59dp"
        android:layout_marginStart="17dp"
        android:layout_marginEnd="17dp"
        android:layout_marginBottom="24dp"
        android:text="@string/select"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/ys_display_regular"
        android:background="@drawable/bg_blue_button"
        android:visibility="gone"
        android:layout_gravity="bottom" />

</LinearLayout>
