<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.vacancy_detail.VacancyDetailFragment">

    <!-- Top Bar высотой 64dp -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurface"
        android:minHeight="64dp"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:navigationIcon="@drawable/ic_arrow_back_24px"
        app:title="@string/vacancy_details"
        app:menu="@menu/vacancy_detail_menu"
        tools:title="Вакансия" />

    <!-- NestedScrollView для прокручиваемого контента -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Название вакансии -->
            <TextView
                android:id="@+id/tvVacancyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:fontFamily="@font/ys_display_bold"
                android:fontWeight="700"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Android разработчик (Kotlin)" />

            <!-- Зарплата -->
            <TextView
                android:id="@+id/tvSalary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="22sp"
                android:fontWeight="500"
                android:fontFamily="@font/ys_display_medium"
                android:textColor="#1A1B22"
                tools:text="от 150 000 до 200 000 ₽" />

            <!-- Card с информацией о компании -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCompany"
                android:layout_width="match_parent"
                android:layout_marginTop="24dp"
                android:layout_height="80dp"
                app:cardCornerRadius="12dp"
                android:background="#E6E8EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- Логотип компании -->
                    <ImageView
                        android:id="@+id/ivCompanyLogo"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_logo"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/company_logo"
                        app:cornerRadius="12dp"
                        />

                    <!-- Информация о компании -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <!-- Название компании -->
                        <TextView
                            android:id="@+id/tvCompanyName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/ys_display_medium"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text='ООО "IT Компания"' />

                        <!-- Город/локация -->
                        <TextView
                            android:id="@+id/tvCompanyLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:fontFamily="@font/ys_display_regular"
                            android:textColor="?android:attr/textColorSecondary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text="Москва, Россия" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Требуемый опыт -->
            <LinearLayout
                android:id="@+id/layoutExperience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                tools:visibility="visible">

                <TextView
                    style="@style/VacancyHeader"
                    android:text="@string/experience"
                    />

                <TextView
                    android:id="@+id/tvExperience"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    tools:text="от 3 до 6 лет" />

                <TextView
                    android:id="@+id/tvWorkFormat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    tools:text="Полная занятость, Удаленная работа" />

            </LinearLayout>

            <!-- Заголовок описания вакансии -->
            <TextView
                android:id="@+id/tvDescriptionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description"
                android:textSize="22sp"
                android:fontFamily="@font/ys_display_medium"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutResponsibilities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:visibility="visible">

                <TextView
                    style="@style/VacancyHeader"
                    android:text="@string/responsibilities"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvResponsibilities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    android:lineHeight="19sp"
                    android:layout_marginBottom="16dp"
                    tools:text="• Разработка новых функций приложения\n• Поддержка и оптимизация существующего кода\n• Участие в code review" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:visibility="visible">

                <TextView
                    style="@style/VacancyHeader"
                    android:text="@string/requirements"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvRequirements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    android:lineHeight="19sp"
                    android:layout_marginBottom="16dp"
                    tools:text="• Разработка новых функций приложения\n• Поддержка и оптимизация существующего кода\n• Участие в code review" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutConditions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:visibility="visible">

                <TextView
                    style="@style/VacancyHeader"
                    android:text="@string/conditions"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvConditions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    android:lineHeight="19sp"
                    android:layout_marginBottom="24dp"
                    tools:text="• Разработка новых функций приложения\n• Поддержка и оптимизация существующего кода\n• Участие в code review" />
            </LinearLayout>

            <!-- Заголовок ключевых навыков -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/layoutSkillsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/key_skills"
                    android:textSize="22sp"
                    android:textStyle="normal"
                    android:fontFamily="@font/ys_display_medium"
                    android:layout_marginBottom="16dp"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvSkillsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/ys_display_regular"
                    android:lineHeight="19sp"
                    android:layout_marginBottom="16dp"
                    tools:text="• Разработка новых функций приложения\n• Поддержка и оптимизация существующего кода\n• Участие в code review" />
            </LinearLayout>

            <!-- Заголовок контактов -->
            <LinearLayout
                android:id="@+id/layoutContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/contacts"
                    android:textSize="22sp"
                    android:fontFamily="@font/ys_display_medium"
                    android:layout_marginBottom="16dp" />

                <!-- Email -->
                <LinearLayout
                    android:id="@+id/layoutEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvEmailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="16sp"
                        android:fontFamily="@font/ys_display_medium"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:fontFamily="@font/ys_display_regular"
                        android:textColor="@color/blue"
                        android:clickable="true"
                        android:focusable="true"
                        tools:text="hr@company.ru" />

                </LinearLayout>

                <!-- Телефон -->
                <LinearLayout
                    android:id="@+id/layoutPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvPhoneLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Телефон"
                        android:textSize="16sp"
                        android:fontFamily="@font/ys_display_medium"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:fontFamily="@font/ys_display_regular"
                        android:textColor="@color/blue"
                        android:clickable="true"
                        android:focusable="true"
                        tools:text="+7 (999) 123-45-67" />

                    <TextView
                        android:id="@+id/tvPhoneComment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:fontFamily="@font/ys_display_regular"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="4dp"
                        android:visibility="visible"
                        tools:text="доб. 123" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
